{
  "name": "recon",
  "version": "0.1.0",
  "description": "A robot explores a fog-covered map using real frontier-based exploration.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctkrug/recon.git"
  },
  "homepage": "https://github.com/ctkrug/recon#readme",
  "bugs": {
    "url": "https://github.com/ctkrug/recon/issues"
  },
  "keywords": [
    "frontier-exploration",
    "canvas",
    "visualization",
    "robotics-simulation",
    "typescript"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^8.57.0",
    "fast-check": "^4.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
